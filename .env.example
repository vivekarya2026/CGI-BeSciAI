# BeSciAI — Environment Variables
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to git (it is already in .gitignore).

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-public-anon-key>

# ─── App Config ───────────────────────────────────────────────────────────────
# The password used by PasswordGate.tsx to protect the app during demos.
# This is NOT a production authentication mechanism.
VITE_APP_PASSWORD=your-demo-password
